# ───────────────────────────────────────────────────────────────────────────
# UCG SCI-Grade Platform v6.0.0 — Environment Variables Template
# ───────────────────────────────────────────────────────────────────────────
# COPY this file to `.env` and fill in real values.
# NEVER commit the real `.env` file to git (it's in .gitignore).

# ── General ────────────────────────────────────────────────────────────────
DEBUG=False
LOG_DIR=~/.ucg_platform/logs
REPORT_DIR=~/.ucg_platform/reports

# ── Database (PostgreSQL — only if backend=postgres) ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ucg_platform
DB_USER=ucg_user
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ── RSA Key Encryption (PersistentKeyManager) ──────────────────────────────
# Password used to encrypt the RSA-4096 private key PEM file.
# If not set, the key is stored UNENCRYPTED (NOT recommended for production).
UCG_KEY_PASSWORD=CHANGE_ME_TO_STRONG_KEY_PASSWORD

# ── DataCite DOI Registration ──────────────────────────────────────────────
# Get credentials: https://datacite.org/membership.html
# Without these, DOIs are generated locally but NOT registered globally.
DATACITE_PREFIX=10.2026
DATACITE_API_TOKEN=
# OR use basic auth (username/password):
DATACITE_USERNAME=
DATACITE_PASSWORD=

# ── Espacenet OPS API (OAuth 2.0) ──────────────────────────────────────────
# Get credentials: https://www.epo.org/registering-registering/registering.html
EPS_OPS_KEY=
EPS_OPS_SECRET=

# ── Crossref API (polite pool — just email for rate limit increase) ───────
CROSSREF_MAILTO=your_email@example.com

# ── IPFS Node (optional, for distributed audit ledger) ────────────────────
# Default: local IPFS daemon. Install: https://docs.ipfs.io/install/
IPFS_API_URL=http://127.0.0.1:5001/api/v0

# ── Google Patents / WIPO Patentscope ──────────────────────────────────────
# No API keys required (public APIs), but User-Agent is set in code.
# For high-volume usage, consider Google Patents API key (if available).

# ── Hugging Face (for SciBERT model download) ─────────────────────────────
# Optional but recommended for higher rate limits.
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=
