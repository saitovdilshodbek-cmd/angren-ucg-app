# ───────────────────────────────────────────────────────────────────────────
# .gitignore for UCG SCI-Grade Platform v6.0.0
# ───────────────────────────────────────────────────────────────────────────

# ── SECRETS (NEVER COMMIT) ─────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.toml
.streamlit/secrets.toml

# ── RSA / Crypto keys ──────────────────────────────────────────────────────
keys/
*.private
*.public.pem.locked

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# ── Database files (local only) ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
log/

# ── Generated reports (regenerated on demand) ──────────────────────────────
reports/
*.docx
!docs/*.docx
patent_certificate_*.pdf
*_Rev*.docx
ucg_theorems_formal.pdf

# ── Test / Coverage ────────────────────────────────────────────────────────
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
mypy_cache/
.pyre/
.pytype/

# ── Jupyter Notebook ───────────────────────────────────────────────────────
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# ── IDE / Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Streamlit ──────────────────────────────────────────────────────────────
.streamlit/cache/

# ── Misc ───────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.rej
